# ── Database (Neon Postgres) ────────────────────────────────
DATABASE_URL="postgres://user:password@ep-xxxx.neon.tech/smartcart?sslmode=require"

# ── Auth (Better Auth) ──────────────────────────────────────
BETTER_AUTH_SECRET="generate-with-openssl-rand-base64-32"
BETTER_AUTH_URL="http://localhost:3000"

# ── AI providers (provider-agnostic — set at least one) ─────
AI_DEFAULT_PROVIDER="openai"          # openai | anthropic | groq | openrouter | ollama
AI_FAST_MODEL="gpt-4o-mini"           # cheap/fast task class (classification, extraction)
AI_PLANNING_MODEL="gpt-4o"            # frontier task class (planning, meal engine, long chat)
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""
GROQ_API_KEY=""
OPENROUTER_API_KEY=""

# ── WhatsApp (Evolution API) ─────────────────────────────────
EVOLUTION_API_URL="https://your-evolution-instance.example.com"
EVOLUTION_API_KEY=""
EVOLUTION_WEBHOOK_SECRET="generate-a-shared-secret"

# ── Payments ──────────────────────────────────────────────────
PAYFAST_MERCHANT_ID=""
PAYFAST_MERCHANT_KEY=""
PAYFAST_PASSPHRASE=""
PAYFAST_MODE="sandbox"                # sandbox | live

YOCO_SECRET_KEY=""
YOCO_WEBHOOK_SECRET=""

STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# ── Catalog connectors ───────────────────────────────────────
SHOPIFY_API_KEY=""
SHOPIFY_API_SECRET=""
WOOCOMMERCE_CONSUMER_KEY=""
WOOCOMMERCE_CONSUMER_SECRET=""

# ── Object storage ───────────────────────────────────────────
BLOB_READ_WRITE_TOKEN=""              # Vercel Blob, or swap for R2 credentials

# ── App ───────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"
