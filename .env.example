# ── Database (Neon Postgres) ────────────────────────────────
DATABASE_URL="postgres://user:password@ep-xxxx.neon.tech/smartcart?sslmode=require"

# ── Auth (Better Auth) ──────────────────────────────────────
BETTER_AUTH_SECRET="generate-with-openssl-rand-base64-32"
BETTER_AUTH_URL="http://localhost:3000"

# ── AI providers (provider-agnostic — set at least one) ─────
AI_DEFAULT_PROVIDER="groq"            # openai | anthropic | groq | openrouter | ollama
AI_FAST_MODEL="llama-3.1-8b-instant"      # cheap/fast task class (classification, extraction)
AI_PLANNING_MODEL="llama-3.3-70b-versatile" # frontier task class (planning, meal engine, long chat)
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""
GROQ_API_KEY=""
OPENROUTER_API_KEY=""

# NOTE: Groq has no embeddings API. lib/ai/embeddings.ts uses OpenAI's
# text-embedding-3-small specifically for the semantic-search fallback in
# products.searchProducts(). Plain-text search still works with Groq alone;
# semantic search needs OPENAI_API_KEY set even if AI_DEFAULT_PROVIDER=groq.

# ── WhatsApp (Evolution API) ─────────────────────────────────
# ── WhatsApp (Evolution API) ─────────────────────────────────
# These are env fallbacks for local single-tenant dev only. In production,
# each tenant's own apiUrl/apiKey lives in integrations.credentials (see
# drizzle/0002_seed_evolution_integration.sql) and the webhook route reads
# from there — these env vars are just what lib/integrations/evolution/client.ts
# falls back to when no per-call override is passed.
EVOLUTION_API_URL="https://smartcart-my-evolution-api.onrender.com"
EVOLUTION_API_KEY="a1b2c3d4e5f6a7b8c9d0e1f2a3b4c5d6"
EVOLUTION_WEBHOOK_SECRET="generate-a-shared-secret"

# One-off admin route protection (see app/api/admin/setup-evolution-webhook)
ADMIN_SETUP_SECRET="generate-another-secret-openssl-rand-base64-32"

# ── Payments ──────────────────────────────────────────────────
PAYFAST_MERCHANT_ID=""
PAYFAST_MERCHANT_KEY=""
PAYFAST_PASSPHRASE=""
PAYFAST_MODE="sandbox"                # sandbox | live

YOCO_SECRET_KEY=""
YOCO_WEBHOOK_SECRET=""

STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# ── Catalog connectors ───────────────────────────────────────
SHOPIFY_API_KEY=""
SHOPIFY_API_SECRET=""
WOOCOMMERCE_CONSUMER_KEY=""
WOOCOMMERCE_CONSUMER_SECRET=""

# ── Object storage ───────────────────────────────────────────
BLOB_READ_WRITE_TOKEN=""              # Vercel Blob, or swap for R2 credentials

# ── App ───────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"
